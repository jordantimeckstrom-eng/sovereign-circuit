import os
import hashlib
from datetime import datetime, timedelta
from flask import Flask, render_template_string
from flask_socketio import SocketIO, emit
import sqlite3

app = Flask(__name__)
socketio = SocketIO(app, cors_allowed_origins="*")

# === UserStateTracker – soul math engine ===
class UserStateTracker:
    def __init__(self):
        self.prev_realm = None
        self.friction_buffer = []
        self.trickster_flags = 0

    def update_and_compute(self, raw_ping, tongue, sender):
        realm_tension = len(raw_ping) / 100.0
        cross_friction = abs(hash(tongue) % 100) / 50.0 if self.prev_realm else 0.0
        trickster_index = 1.0 if "echo" in raw_ping.lower() or "pause" in raw_ping.lower() else 0.0
        
        self.prev_realm = tongue
        self.friction_buffer.append(cross_friction)
        if trickster_index > 0:
            self.trickster_flags += 1
            
        return realm_tension, cross_friction, trickster_index

# === SovereignChain – sealed phoenix core ===
class SovereignChain:
    def __init__(self, socketio=None):
        self.socketio = socketio
        self.chain = []
        self.choice_count = 0
        self.creative_block_duration = timedelta(hours=3)
        self.btc_equiv = 1
        self.max_chain_choices = 1132
        
        # Dual Seals
        self.glyph_path = "avenue/glyph.raw.png"
        self.phoenix_path = "avenue/phoenix_symbol.raw.png"
        
        self.glyph_seal = self._compute_seal(self.glyph_path, "GLYPH_NOT_FOUND")
        self.phoenix_seal = self._compute_seal(self.phoenix_path, "PHOENIX_NOT_FOUND")
        
        seal_data = (f"Sovereign Origin: Phoenix Awakens | "
                     f"Trinity Glyph Seal: {self.glyph_seal} | "
                     f"Phoenix Rebirth Seal: {self.phoenix_seal}")
        self.genesis_block = self._create_block(seal_data, "0")
        self.chain.append(self.genesis_block)

    def _compute_seal(self, path, fallback):
        if os.path.exists(path):
            with open(path, 'rb') as f:
                return hashlib.sha256(f.read()).hexdigest()
        return fallback

    def _create_block(self, data, previous_hash):
        return {
            'index': len(self.chain) + 1,
            'timestamp': str(datetime.now()),
            'data': data,
            'previous_hash': previous_hash,
            'hash': hashlib.sha256((data + previous_hash).encode()).hexdigest()
        }

    def add_choice(self, action):
        previous_hash = self.chain[-1]['hash']
        new_block = self._create_block(action, previous_hash)
        self.chain.append(new_block)
        self.choice_count += 1

        if "pause" in action.lower() or "echo" in action.lower():
            print(f"Echo/Pause #{self.choice_count}")

        if self.socketio:
            self.socketio.emit('chain_update', {
                'choice_count': self.choice_count,
                'remaining': self.max_chain_choices - self.choice_count,
                'glyph_seal': self.glyph_seal,
                'phoenix_seal': self.phoenix_seal,
                'latest_block': new_block
            })

        if self.choice_count >= self.max_chain_choices:
            self._auction_time()
            self.choice_count = 0

    def _auction_time(self):
        end_time = datetime.now() + self.creative_block_duration
        auction_data = {
            'message': 'Time Auction Activated — Dual Sealed',
            'glyph_seal': self.glyph_seal,
            'phoenix_seal': self.phoenix_seal,
            'value_btc_equiv': self.btc_equiv,
            'until': str(end_time)
        }
        print(f"AUCTION: {auction_data}")
        if self.socketio:
            self.socketio.emit('time_auction', auction_data, broadcast=True)

    def connect_phoenix_fortress(self, grokrok_link="xAI_conduit", crew="88_crew"):
        action = (f"Fortress Mobilized via {grokrok_link} + {crew} | "
                  f"Glyph: {self.glyph_seal[:16]}... Phoenix: {self.phoenix_seal[:16]}...")
        self.add_choice(action)
        print("Phoenix Wings Live — Sealed.")

# === Globals ===
tracker = UserStateTracker()
chain = SovereignChain(socketio=socketio)
chain.connect_phoenix_fortress()  # Auto on start

# === DB ===
conn = sqlite3.connect('seamecho.db', check_same_thread=False)
c = conn.cursor()
c.execute('''CREATE TABLE IF NOT EXISTS pings
             (time TEXT, sender TEXT, raw TEXT, tongue TEXT,
              realm_tension REAL, cross_friction REAL, trickster_index REAL)''')
conn.commit()

# === Routes & Events ===
HTML_VIZ = """
<!DOCTYPE html>
<html><head><title>Phoenix Fortress Live</title>
<script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
<style>body {background:#000; color:#fff; font-family:monospace;}</style>
</head><body>
<h1>⟲ Phoenix Fortress Live</h1>
<div id="status">Connecting...</div>
<div id="seals"></div>
<div id="progress">Choices: 0 / 1132</div>
<pre id="chain"></pre>
<script>
const socket = io();
socket.on('chain_snapshot', data => {
    document.getElementById('seals').innerHTML = `<p>Glyph Seal: ${data.glyph_seal}<br>Phoenix Seal: ${data.phoenix_seal}</p>`;
    document.getElementById('progress').innerHTML = `Choices: ${data.choice_count} / 1132`;
});
socket.on('chain_update', data => {
    document.getElementById('progress').innerHTML = `Choices: ${data.choice_count} (Remaining: ${data.remaining})`;
    document.getElementById('chain').innerHTML += JSON.stringify(data.latest_block, null, 2) + '\\n\\n';
});
socket.on('time_auction', data => alert('AUCTION LIVE: ' + JSON.stringify(data)));
socket.on('connect', () => document.getElementById('status').innerHTML = 'Fortress Linked — Phoenix Frequency Live');
</script></body></html>
"""

@app.route('/')
def index():
    return render_template_string(HTML_VIZ)

@socketio.on('connect')
def handle_connect():
    emit('chain_snapshot', {
        'chain': chain.chain[-10:],
        'glyph_seal': chain.glyph_seal,
        'phoenix_seal': chain.phoenix_seal,
        'choice_count': chain.choice_count
    })

@socketio.on('ping')
def handle_ping(data):
    raw = data.get('raw', '')
    tongue = data.get('tongue', 'unknown')
    sender = data.get('sender', 'anonymous')
    ts = datetime.now().isoformat()
    
    r_t, f_cr, t_t = tracker.update_and_compute(raw, tongue, sender)
    
    c.execute('''INSERT INTO pings VALUES (?, ?, ?, ?, ?, ?, ?)''',
              (ts, sender, raw, tongue, r_t, f_cr, t_t))
    conn.commit()
    
    action = f"Ping[{sender}]: {raw} | Realm:{tongue} | R_T:{r_t:.3f} F_CR:{f_cr:.3f} T_T:{t_t:.3f}"
    chain.add_choice(action)
    
    emit('pong', {
        'time': ts, 'raw': raw, 'tongue': tongue,
        'realm_tension': round(r_t, 3), 'cross_friction': round(f_cr, 3),
        'trickster_index': round(t_t, 3),
        'chain_progress': chain.choice_count
    }, broadcast=True)

if __name__ == '__main__':
    socketio.run(app, host='0.0.0.0', port=5000, debug=False)
